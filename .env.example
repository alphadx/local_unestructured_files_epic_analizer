# Gemini API key (required for AI classification and embeddings)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override default model names
# GEMINI_FLASH_MODEL is used for classification / semantic extraction.
# GEMINI_EMBEDDING_MODEL is used for vector embeddings and semantic search.
GEMINI_FLASH_MODEL=gemini-2.5-flash-lite
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# Path on the HOST machine to analyse (will be mounted read-only)
SCAN_PATH=/mnt/c/temp/fiasco_test

# App config
MAX_FILE_SIZE_MB=10
LOG_LEVEL=INFO

# ── Phase 2: PostgreSQL ───────────────────────────────────────────────────
# Connection URL for the persistent job/document/audit database.
# docker compose sets this automatically from the postgres service.
# For local development without Docker: create a database named "analyzer".
DATABASE_URL=postgresql+asyncpg://app:secret@localhost:5432/analyzer
# PostgreSQL service credentials (used by docker compose)
POSTGRES_USER=app
POSTGRES_PASSWORD=secret
POSTGRES_DB=analyzer

# ── Phase 2: Redis (Celery broker + pub/sub) ─────────────────────────────
REDIS_URL=redis://localhost:6379/0

# Optional: Google Drive / SharePoint remote scanning support
# Either provide credentials here or include them in the job's source_options.
GOOGLE_DRIVE_SERVICE_ACCOUNT_JSON={}
GOOGLE_DRIVE_FOLDER_ID=
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=

# Optional: remote vector store headers.
# Leave empty for none, or use JSON / key=value pairs.
# VECTOR_STORE_HEADERS={"Authorization":"Bearer ..."}

PUBLIC_API_URL=http://localhost:8080
